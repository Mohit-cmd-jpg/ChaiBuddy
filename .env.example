# Environment Variables Template
# Copy this file to .env and fill in your actual values

# ===============================================
# PRIMARY AI MODEL: GitHub Models (Best Performance)
# ===============================================
# Supports: Claude 3.5 Sonnet (recommended), GPT-4o
# GitHub Personal Access Token (required for GitHub Models)
# Get from: https://github.com/settings/tokens
# Scopes needed: read:user (minimal)
GITHUB_PAT=your_github_personal_access_token

# ===============================================
# FALLBACK AI MODEL: Google Gemini (Always Required)
# ===============================================
# Gemini API Key (required)
# Get from: https://aistudio.google.com/app/apikeys
GEMINI_API_KEY=your_gemini_api_key_here

# ===============================================
# SERVER CONFIGURATION
# ===============================================
# Flask Environment
FLASK_ENV=development

# Server Port (default: 5000 for local, 3000 for Vercel)
PORT=5000

# ===============================================
# NOTES
# ===============================================
# • App tries GitHub Model (Claude) first for better responses
# • Falls back to Gemini automatically if GitHub fails
# • Both keys required for full functionality
# • GitHub Models are faster and more capable
# • Gemini serves as reliable fallback
